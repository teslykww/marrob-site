# Публичная переменная: единый endpoint для форм (относительный путь — тот же домен).
VITE_LEAD_API_URL=/api/bitrix-lead

# Опционально — отдельные URL вместо VITE_LEAD_API_URL:
# VITE_LEAD_FORM_URL=
# VITE_CONTACT_FORM_URL=
# VITE_DEALER_FORM_URL=

# Только на сервере (Vercel → Settings → Environment Variables), без префикса VITE_.
# Полный URL вебхука на метод crm.lead.add (входящий вебхук в Битрикс24 — храните в секрете).
# После утечки ключа перевыпустите вебхук в портале и обновите значение.
# BITRIX24_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.ru/rest/1/YOUR_SECRET/crm.lead.add.json
